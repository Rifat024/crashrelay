{
  "name": "crashrelay",
  "version": "0.1.1",
  "description": "Catch backend crashes, HTTP 5xx responses, and error-log lines (plus frontend JS errors via crashrelay-browser) and auto-file tickets in Jira or GitHub Issues.",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "crashrelay": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "tsc -p tsconfig.test.json && find .test-build -name '*.test.js' -print0 | xargs -0 node --test",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "error-tracking",
    "jira",
    "github-issues",
    "monitoring",
    "crash-reporting",
    "cli",
    "ticketing"
  ],
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "commander": "^12.1.0",
    "node-cron": "^4.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.6.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rifat024/crashrelay.git"
  }
}
